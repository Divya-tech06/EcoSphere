datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Master Data models

model Department {
  id                String              @id @default(uuid())
  name              String
  code              String              @unique
  head              String
  parentDepartmentId String?
  parentDepartment  Department?         @relation("DepartmentToSubDepartments", fields: [parentDepartmentId], references: [id], onDelete: Cascade)
  subDepartments    Department[]        @relation("DepartmentToSubDepartments")
  employeeCount     Int                 @default(0)
  status            String              @default("Active")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  users             User[]
  environmentalGoals EnvironmentalGoal[]
  carbonTransactions CarbonTransaction[]
  audits            Audit[]
  complianceIssues  ComplianceIssue[]
  departmentScores  DepartmentScore[]
}

enum CategoryType {
  CSR_ACTIVITY
  CHALLENGE
}

model Category {
  id        String       @id @default(uuid())
  name      String       @unique
  type      CategoryType
  status    String       @default("Active")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  csrActivities CSRActivity[]
  challenges    Challenge[]
}

model EmissionFactor {
  id           String              @id @default(uuid())
  name         String
  activityType String
  unit         String
  co2PerUnit   Float               // calculated CO2 value per unit
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions CarbonTransaction[]
}

model ProductESGProfile {
  id                 String   @id @default(uuid())
  productName        String
  sku                String   @unique
  carbonFootprintUnit Float    // carbon footprint per unit
  esgNotes           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum GoalStatus {
  Active
  On_Track    @map("On Track")
  Completed
  At_Risk     @map("At Risk")
}

model EnvironmentalGoal {
  id           String      @id @default(uuid())
  name         String
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  targetCO2    Float
  currentCO2   Float       @default(0.0)
  deadline     DateTime
  status       GoalStatus  @default(Active)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model ESGPolicy {
  id            String                  @id @default(uuid())
  title         String
  description   String
  category      String
  version       String
  effectiveDate DateTime
  status        String                  @default("Draft")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  acknowledgements PolicyAcknowledgement[]
}

model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  unlockRule  Json     // Supports JSON schema for rules like XP threshold
  icon        String   @default("award")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reward {
  id             String   @id @default(uuid())
  name           String   @unique
  description    String
  pointsRequired Int
  stock          Int
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Transactional Data models

enum CarbonSourceType {
  Purchase
  Manufacturing
  Expense
  Fleet
}

model CarbonTransaction {
  id               String           @id @default(uuid())
  departmentId     String
  department       Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  sourceType       CarbonSourceType
  sourceRecordRef  String
  emissionFactorId String
  emissionFactor   EmissionFactor   @relation(fields: [emissionFactorId], references: [id], onDelete: Cascade)
  quantity         Float
  calculatedCO2    Float
  date             DateTime
  autoGenerated    Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model CSRActivity {
  id               String                  @id @default(uuid())
  title            String
  categoryId       String
  category         Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  description      String
  evidenceRequired Boolean                 @default(true)
  status           String                  @default("Active")
  date             DateTime
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  participations   EmployeeParticipation[]
}

enum ApprovalStatus {
  Pending
  Approved
  Rejected
}

model EmployeeParticipation {
  id            String         @id @default(uuid())
  employeeId    String
  employee      User           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  csrActivityId String
  csrActivity   CSRActivity    @relation(fields: [csrActivityId], references: [id], onDelete: Cascade)
  proofFileUrl  String?
  approvalStatus ApprovalStatus @default(Pending)
  pointsEarned  Int            @default(0)
  completionDate DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum ChallengeDifficulty {
  Easy
  Medium
  Hard
}

enum ChallengeStatus {
  Draft
  Active
  Under_Review @map("Under Review")
  Completed
  Archived
}

model Challenge {
  id               String                   @id @default(uuid())
  title            String
  categoryId       String
  category         Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  description      String
  xp               Int                      @default(0)
  difficulty       ChallengeDifficulty      @default(Easy)
  evidenceRequired Boolean                  @default(true)
  deadline         DateTime
  status           ChallengeStatus          @default(Draft)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  participations   ChallengeParticipation[]
}

model ChallengeParticipation {
  id             String         @id @default(uuid())
  challengeId    String
  challenge      Challenge      @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       User           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  progress       Float          @default(0.0) // progress %
  proofFileUrl   String?
  approvalStatus ApprovalStatus @default(Pending)
  xpAwarded      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PolicyAcknowledgement {
  id            String      @id @default(uuid())
  policyId      String
  policy        ESGPolicy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      User        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  acknowledgedAt DateTime   @default(now())
  status        String      @default("Acknowledged")
}

model Audit {
  id               String            @id @default(uuid())
  title            String
  departmentId     String
  department       Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  auditor          String
  date             DateTime
  findings         String
  status           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  complianceIssues ComplianceIssue[]
}

enum ComplianceSeverity {
  Low
  Medium
  High
}

enum ComplianceStatus {
  Open
  Resolved
}

model ComplianceIssue {
  id           String             @id @default(uuid())
  auditId      String?
  audit        Audit?             @relation(fields: [auditId], references: [id], onDelete: SetNull)
  title        String
  description  String
  severity     ComplianceSeverity @default(Medium)
  departmentId String
  department   Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  ownerId      String
  owner        User               @relation("UserComplianceIssues", fields: [ownerId], references: [id], onDelete: Cascade)
  dueDate      DateTime
  status       ComplianceStatus   @default(Open)
  overdue      Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model DepartmentScore {
  id                 String     @id @default(uuid())
  departmentId       String
  department         Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  period             String     // e.g. "2026-Q1", "2026-Q2", "2026-07"
  environmentalScore Float      @default(0.0)
  socialScore        Float      @default(0.0)
  governanceScore    Float      @default(0.0)
  totalScore         Float      @default(0.0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

// Supporting models

enum Role {
  ADMIN
  APPROVER
  EMPLOYEE
}

model User {
  id                    String                   @id @default(uuid())
  name                  String?
  email                 String                   @unique
  password              String
  role                  Role                     @default(EMPLOYEE)
  departmentId          String?
  department            Department?              @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  totalXP               Int                      @default(0)
  redeemablePoints      Int                      @default(0)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  
  participations        EmployeeParticipation[]
  challengeParticipations ChallengeParticipation[]
  acknowledgements      PolicyAcknowledgement[]
  ownedComplianceIssues ComplianceIssue[]        @relation("UserComplianceIssues")
  notifications         Notification[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ESGConfiguration {
  id                                 String  @id @default("singleton")
  environmentalWeight                Float   @default(40.0)
  socialWeight                       Float   @default(30.0)
  governanceWeight                   Float   @default(30.0)
  autoEmissionCalculation            Boolean @default(true)
  requireEvidenceForCSR             Boolean @default(true)
  autoAwardBadges                    Boolean @default(true)
  emailAlertsForComplianceIssues     Boolean @default(true)
}
